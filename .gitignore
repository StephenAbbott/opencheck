# ---- Environment ----
.env
.env.local
.env.*.local

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
dist/
build/
*.egg-info/
*.egg
.venv/
venv/
env/

# uv
.uv/

# ---- Node / Frontend ----
node_modules/
.pnpm-store/
.yarn/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite / build output
frontend/dist/
frontend/.vite/
# Vite drops these next to the config when esbuild jit-compiles it.
frontend/vite.config.ts.timestamp-*.mjs
# bods-dagre images are copied in by a vite plugin at build start.
frontend/public/bods-dagre-images/
*.local

# ---- Editors / OS ----
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Docker ----
# Keep docker-compose.yml and Dockerfiles; ignore local overrides
docker-compose.override.yml

# ---- OpenCheck runtime data ----
# Curated demo fixtures live under data/cache/demos/ and ARE checked in.
# Live runtime cache is ignored.
data/cache/live/
data/cache/*.tmp

# Pre-built source adapter databases (large local files, built by scripts/extract_*.py)
data/*.db

# Exports generated at runtime
exports/
*.export.json
*.export.zip

# ---- TypeScript build info ----
tsconfig.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# ---- Logs ----
*.log
logs/
