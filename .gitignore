__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
dist/
build/
*.egg-info/
*.egg
.venv/
venv/
env/

# uv
.uv/

# ---- Node / Frontend ----
node_modules/
.pnpm-store/
.yarn/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite / build output
frontend/dist/
frontend/.vite/
# Vite drops these next to the config when esbuild jit-compiles it.
frontend/vite.config.ts.timestamp-*.mjs
# bods-dagre-images/ is now committed as a static asset (no longer generated
# by a vite plugin — the @openownership/bods-dagre package was removed in
# Phase 44 when the graph renderer was migrated to Cytoscape.js).
*.local

# ---- Editors / OS ----
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Docker ----
# Keep docker-compose.yml and Dockerfiles; ignore local overrides
docker-compose.override.yml

# ---- OpenCheck runtime data ----
# Curated demo fixtures live under data/cache/demos/ and ARE checked in.
# Live runtime cache is ignored.
data/cache/live/
data/cache/*.tmp

# Pre-built source adapter databases (large local files, built by scripts/extract_*.py)
data/*.db

# Stray pre-built adapter DBs built/pointed at from backend/ (OpenTender,
# ariregister, etc.) — multi-hundred-MB artifacts, never committed. Includes the
# SQLite WAL/SHM sidecars that appear next to an open DB.
backend/*.db
backend/*.db-wal
backend/*.db-shm

# Stray local runtime cache / built databases under backend/ (live API caches,
# UK PSC databases, etc. — large, never committed).
backend/data/

# Downloaded GEM/GEOT source CSVs (re-downloaded at runtime; the committed
# artifact is backend/opencheck/data/geot_projects.json.gz, which stays tracked).
data/gem/
backend/opencheck/data/gem/

# Sanctioned-securities index built from OpenSanctions securities.csv (CC-BY-NC).
# Built by scripts/extract_securities.py; not redistributed in the repo.
data/securities/
backend/data/securities/

# Cowork / local scratch outputs (favicons, render previews, etc.).
outputs/

# macOS folder metadata
.DS_Store

# Exports generated at runtime
exports/
*.export.json
*.export.zip

# ---- TypeScript build info ----
tsconfig.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# ---- Logs ----
*.log
logs/

# Estonia sweep artefacts (release assets, not committed)
data/estonia/
data/ariregister_raw/

# GLEIF autocompletions eval harness response cache (issue #27) — not committed
backend/scripts/.gleif_eval_cache.json

# Session artefacts — never commit
_to_delete/
*.bundle
unilever.json
tmp_opencheck_audit.tgz
