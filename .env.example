# OpenCheck — environment variables.
# Copy this file to `.env` and fill in real values as you progress through phases.
# Phase 0 stubs run without any API keys.

# ---------------- Phase 0+ ----------------

# Optional. When true, live source adapters are allowed to make real HTTP calls.
# When false (default in Phase 0), all adapters return stub responses.
OPENCHECK_ALLOW_LIVE=false

# CORS origin for the frontend dev server.
OPENCHECK_CORS_ORIGIN=http://localhost:5173

# ---------------- Phase 1 — first live adapter ----------------

# UK Companies House API key.
# Get one at https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# ---------------- Phase 2 — remaining entity sources ----------------

# GLEIF is a public, unauthenticated API — no key needed.

# OpenSanctions API key (free tier is sufficient for the hosted demo).
# Register at https://www.opensanctions.org/account/
OPENSANCTIONS_API_KEY=

# OpenAleph API key (required for some collections, not all).
# Instance: https://search.openaleph.org/
OPENALEPH_API_KEY=

# ---------------- Phase 3 — person sources ----------------

# EveryPolitician is served via OpenSanctions' PEPs dataset — reuses OPENSANCTIONS_API_KEY.

# Wikidata public SPARQL endpoint — no key required; respect WDQS rate limits.
# Override if using a private mirror or QLever endpoint.
WIKIDATA_SPARQL_ENDPOINT=https://query.wikidata.org/sparql

# ---------------- Optional — LLM for intent extraction and phrasing ----------------

# Anthropic API key (for intent extraction, disambiguation, and narrative phrasing).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=
